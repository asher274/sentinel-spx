# =============================================================================
# SENTINEL TRADING BOT — ENVIRONMENT VARIABLES
# Copy to .env and fill in all values before running.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# Strong random password for Postgres (generate with: openssl rand -base64 32)
POSTGRES_PASSWORD=

# DB connection details (used by Python scripts)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=sentinel
DB_USER=sentinel

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------

# Strong random password for Redis (generate with: openssl rand -base64 32)
REDIS_PASSWORD=

# Redis connection details (used by Python scripts)
REDIS_HOST=localhost
REDIS_PORT=6380

# -----------------------------------------------------------------------------
# GRAFANA
# -----------------------------------------------------------------------------

# Grafana admin dashboard password
GRAFANA_PASSWORD=

# -----------------------------------------------------------------------------
# MARKET DATA APIs
# -----------------------------------------------------------------------------

# Polygon.io API key — Advanced plan required for real-time data and options flow
POLYGON_API_KEY=

# Unusual Whales API key — for options flow and dark pool data
UNUSUAL_WHALES_API_KEY=

# Perplexity Sonar API key — for AI-powered news and sentiment analysis
PERPLEXITY_API_KEY=

# FRED (Federal Reserve Economic Data) API key — free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# -----------------------------------------------------------------------------
# NOTIFICATIONS
# -----------------------------------------------------------------------------

# Telegram bot token — obtain from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat ID — get from @userinfobot on Telegram
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# DISCORD
# -----------------------------------------------------------------------------

# Discord bot token — from Discord Developer Portal
DISCORD_BOT_TOKEN=

# Channel IDs — right-click channel in Discord (Developer Mode must be on)
DISCORD_COMMAND_CHANNEL_ID=    # #sentinel-command: bot receives commands here
DISCORD_SIGNAL_CHANNEL_ID=     # #signals: trade signals posted here
DISCORD_ALERTS_CHANNEL_ID=     # #alerts: risk alerts and system warnings
DISCORD_PAPER_CHANNEL_ID=      # #paper-trades: paper trading activity log
DISCORD_REPORT_CHANNEL_ID=     # #daily-report: end-of-day performance summary
DISCORD_HEALTH_CHANNEL_ID=     # #sentinel-health: system health and uptime

# -----------------------------------------------------------------------------
# INTERACTIVE BROKERS (Phase 2)
# -----------------------------------------------------------------------------

# Paper trading credentials (used in Phase 0, 1, and 2 paper mode)
IBKR_USERNAME=
IBKR_PASSWORD=

# Live trading credentials (Phase 2 live only — do NOT set until ready)
IBKR_LIVE_USERNAME=
IBKR_LIVE_PASSWORD=

# Trading mode: paper or live
IBKR_TRADING_MODE=paper

# API port: 4002 for paper, 4001 for live
IBKR_PORT=4002

# VNC password for IB Gateway remote desktop debugging
VNC_PASSWORD=

# -----------------------------------------------------------------------------
# AI / OPENCLAW
# -----------------------------------------------------------------------------

# Anthropic Claude API key — used by OpenClaw and any Claude-powered analysis
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# SENTINEL SYSTEM
# -----------------------------------------------------------------------------

# Current operating phase: 0 (data collection), 1 (paper trading), 2 (live)
SENTINEL_PHASE=0
